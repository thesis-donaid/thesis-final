# ============================================
# Blockchain Private Key
# ============================================
# The private key of the wallet that will deploy the contract
# and record proofs from the backend. NEVER commit this file!
#
# How to get this:
# 1. Install MetaMask browser extension
# 2. Create a new wallet (or use existing)
# 3. Go to Account Details → Export Private Key
# 4. Copy the key (starts with 0x...)
POLYGON_PRIVATE_KEY=0xd6420b75c9e529344b1af79c50161d8420f37ba98d3f2ad057b837ae784f87f8

# ============================================
# Polygon Amoy Testnet (for development)
# ============================================
# Free RPC from Polygon:
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Or get a free one from Alchemy/Infura:
# 1. Sign up at https://www.alchemy.com/
# 2. Create an app → Select "Polygon Amoy"
# 3. Copy the HTTPS URL
# POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY

# ============================================
# Polygon Mainnet (for production)
# ============================================
# Free RPC:
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com

# Or use Alchemy/Infura for better reliability:
# POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ============================================
# Sepolia (Ethereum testnet, optional)
# ============================================
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/27282b5643044f51865638953c3552eb
SEPOLIA_PRIVATE_KEY=0xd6420b75c9e529344b1af79c50161d8420f37ba98d3f2ad057b837ae784f87f8
